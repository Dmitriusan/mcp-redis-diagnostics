{
  "name": "mcp-redis-diagnostics",
  "version": "0.1.0",
  "description": "MCP server for Redis diagnostics — analyze memory usage, slowlog, client connections, and keyspace health with AI-powered recommendations",
  "author": "Dmytro Lisnichenko",
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "mcp-redis-diagnostics": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:integration": "vitest run tests/integration/",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "build/**/*.js",
    "!build/__tests__",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "redis",
    "diagnostics",
    "memory-analysis",
    "slowlog",
    "performance",
    "monitoring",
    "ai",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dmitriusan/mcp-redis-diagnostics"
  },
  "homepage": "https://github.com/Dmitriusan/mcp-redis-diagnostics#readme",
  "bugs": {
    "url": "https://github.com/Dmitriusan/mcp-redis-diagnostics/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ioredis": "^5.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
